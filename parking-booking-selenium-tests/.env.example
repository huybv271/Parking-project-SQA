# UI under test
BASE_URL=http://localhost:3000
LOGIN_PATH=/auth/login
RESERVATION_PATH=/customer/reservation
HISTORY_PATH=/customer/history

# Customer account
CUSTOMER_USERNAME=customer_username
CUSTOMER_PASSWORD=customer_password

# Admin account for Delete Spot tests
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
ADMIN_LOGIN_PATH=/staff/auth/login
ADMIN_SPOT_AREA_PATH=/admin/spots/A
ADMIN_DELETED_SPOTS_PATH=/admin/spots/trash
ADMIN_SPOT_AREAS=A,B

# Browser
BROWSER=chrome
HEADLESS=false
WINDOW_WIDTH=1440
WINDOW_HEIGHT=900
SELENIUM_TIMEOUT=15

# Optional API values for Postman/Newman
API_BASE_URL=http://localhost:8081
USER_BASE=/user
POSTMAN_SPOT_ID=1
POSTMAN_RESERVATION_ID=

# Optional database assertions and rollback.
# Keep DB_ENABLE=false until you confirm local DB credentials and table names.
DB_ENABLE=false
DB_HOST=localhost
DB_PORT=3306
DB_NAME=parking
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

# Rollback only automation-created records that match this prefix.
TEST_PLATE_PREFIX=AUTO
