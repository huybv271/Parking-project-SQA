# Selenium Test Configuration
# Copy this file to .env and fill in your actual values

# Application URL
BASE_URL=http://localhost:3000

# Staff/Admin Credentials
STAFF_USERNAME=staff1
STAFF_PASSWORD=123456
ADMIN_USERNAME=admin1
ADMIN_PASSWORD=123456

# Customer Credentials  
CUSTOMER_USERNAME=0987654321
CUSTOMER_PASSWORD=123456abcd

# Browser Settings
HEADLESS=false
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Timeouts (seconds)
DEFAULT_WAIT=10
PAGE_LOAD_WAIT=30

# Screenshot Settings
SCREENSHOT_ON_FAILURE=true

# Optional: PlateRecognizer API Key
# Get from https://platerecognizer.com/
PLATE_RECOGNIZER_API_KEY=
